# changing window focus
alt-h: yabai -m window --focus west
alt-j: yabai -m window --focus south
alt-k: yabai -m window --focus north
alt-l: yabai -m window --focus east

# modifying window size
alt-f: yabai -m window --toggle zoom-fullscreen
alt-b: yabai -m space --balance

# create a new space
alt-s: yabai -m space --create

# move window between spaces
alt-p: yabai -m window --space prev
alt-n: yabai -m window --space next

# move to given space
alt-1: yabai -m space --focus 1
alt-2: yabai -m space --focus 2
alt-3: yabai -m space --focus 3
alt-4: yabai -m space --focus 4
alt-5: yabai -m space --focus 5
alt-6: yabai -m space --focus 6
alt-7: yabai -m space --focus 7
alt-8: yabai -m space --focus 8
alt-9: yabai -m space --focus 9

# move windows around the screen
alt+shift-h: yabai -m window --swap west
alt+shift-j: yabai -m window --swap south
alt+shift-k: yabai -m window --swap north
alt+shift-l: yabai -m window --swap east


# move and split window 
alt+ctrl-h: yabai -m window --warp west
alt+ctrl-j: yabai -m window --warp south
alt+ctrl-k: yabai -m window --warp north
alt+ctrl-l: yabai -m window --warp east

# start/stop yabai
alt+ctrl-q: yabai --stop-service
alt+ctrl-s: yabai --start-service
alt+ctrl-r: yabai --restart-service

# move window to different display
alt+cmd-j: yabai -m window --display west
alt+cmd-k: yabai -m window --display east

# switching monitors
alt+cmd-h: yabai -m display --focus west
alt+cmd-l: yabai -m display --focus east
